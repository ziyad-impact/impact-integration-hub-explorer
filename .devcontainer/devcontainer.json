{
  "name": "impact.com Integration Hub Explorer",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11",

  // Install Python deps once when the codespace is first created.
  "postCreateCommand": "pip install --user -r requirements.txt",

  // Auto-start the FastAPI server every time the codespace starts.
  // Backgrounded so the codespace can finish attaching; logs go to /tmp.
  "postStartCommand": "nohup uvicorn main:app --host 0.0.0.0 --port 8001 > /tmp/uvicorn.log 2>&1 &",

  // Forward the app port and prompt to open it in a new browser tab.
  "forwardPorts": [8001],
  "portsAttributes": {
    "8001": {
      "label": "Integration Hub Explorer",
      "onAutoForward": "openBrowser",
      "protocol": "http"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"]
    }
  }
}
