{
  "name": "impact.com Integration Hub Explorer",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11",

  // Install Python deps when the codespace is first created.
  // Use `python -m pip` (not bare `pip`) to guarantee we install into the
  // exact Python that VS Code's task will later use to run uvicorn.
  "postCreateCommand": "python -m pip install -r requirements.txt",

  // The app is started by a VS Code task with `runOn: folderOpen` (defined
  // in .vscode/tasks.json). That runs visibly in a terminal panel, so any
  // startup error is immediately diagnosable — unlike postStartCommand,
  // which runs in a hidden shell and fails silently if anything goes wrong.

  // Forward the app port and prompt to open it in a new browser tab.
  "forwardPorts": [8001],
  "portsAttributes": {
    "8001": {
      "label": "Integration Hub Explorer",
      "onAutoForward": "openBrowser",
      "protocol": "http"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"],
      "settings": {
        // Lets the "Start App" task in .vscode/tasks.json auto-run on open
        // without prompting. Codespaces auto-trusts the workspace, so this
        // value goes through without intervention.
        "task.allowAutomaticTasks": "on"
      }
    }
  }
}
